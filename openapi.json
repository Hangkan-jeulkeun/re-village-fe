  "info": {
    "title": "제주 리-빌리지 API",
    "description": "제주 유휴 자산 매칭 플랫폼 백엔드 API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "youth@example.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123!"
          }
        },
        "required": ["email", "password"]
      },
      "AutofillHouseDto": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string",
            "example": "제주특별자치도 제주시 한림읍 ..."
          },
          "latitude": {
            "type": "number",
            "example": 33.4996
          },
          "longitude": {
            "type": "number",
            "example": 126.5312
          },
          "assetType": {
            "type": "string",
            "enum": ["EMPTY_HOUSE", "WAREHOUSE", "FIELD", "OTHER"],
            "example": "EMPTY_HOUSE"
          },
          "areaSqm": {
            "type": "number",
            "example": 72
          },
          "floorCount": {
            "type": "number",
            "example": 1,
            "description": "층수(단층=1)"
          },
          "hasYard": {
            "type": "boolean",
            "example": true,
            "description": "마당 유무"
          },
          "hasParking": {
            "type": "boolean",
            "example": true,
            "description": "주차 가능 여부"
          },
          "photoUrls": {
            "example": ["https://cdn.example.com/building-1.jpg"],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "RequestVerificationDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "010-1234-5678"
          }
        },
        "required": ["phone"]
      },
      "VerifyCodeDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "010-1234-5678"
          },
          "code": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": ["phone", "code"]
      },
      "LookupApplicationDetailDto": {
        "type": "object",
        "properties": {
          "applicationId": {
            "type": "string",
            "format": "uuid"
          },
          "phone": {
            "type": "string",
            "example": "010-1234-5678"
          },
          "code": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": ["applicationId", "phone", "code"]
      },
      "CancelApplicationDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "010-1234-5678"
          },
          "code": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": ["phone", "code"]
      },
      "UpdateStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "RECEIVED",
              "REVIEWING",
              "REMODELING",
              "LEASING",
              "COMPLETED",
              "REJECTED"
            ],
            "example": "REVIEWING"
          },
          "rejectReason": {
            "type": "string",
            "example": "사업계획 보완 필요"
          },
          "residentAgeGroup": {
            "type": "string",
            "example": "20대, 30대"
          },
          "leasePurpose": {
            "type": "string",
            "example": "카페 창업"
          },
          "occupantCount": {
            "type": "number",
            "example": 2
          },
          "remodelSummary": {
            "type": "string",
            "example": "주방/전기 배선/화장실 리모델링 완료"
          },
          "managerContact": {
            "type": "string",
            "example": "제주시 건축과 064-000-0000"
          }
        },
        "required": ["status"]
      }
    }
  }
}
