        },
        "tags": ["applications"]
      }
    },
    "/api/v1/applications/lookup/detail": {
      "post": {
        "operationId": "ApplicationsController_lookupDetail",
        "summary": "인증번호 검증 후 특정 신청 상세 조회",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LookupApplicationDetailDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["applications"]
      }
    },
    "/api/v1/applications/{id}/cancel": {
      "patch": {
        "operationId": "ApplicationsController_cancel",
        "summary": "신청 취소 (전화번호 인증 기반)",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelApplicationDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": ["applications"]
      }
    },
    "/api/v1/applications/admin/summary": {
      "get": {
        "operationId": "ApplicationsController_adminSummary",
        "summary": "관리자 신청 현황 요약",
        "parameters": [
          {
            "name": "month",
            "required": false,
            "in": "query",
            "description": "YYYY-MM 형식",
            "schema": {
              "example": "2026-04",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": ["applications"],
        "security": [
          {
            "access-token": []
          }
        ]
      }
    },
    "/api/v1/applications/admin/list": {
      "get": {
        "operationId": "ApplicationsController_adminList",
        "summary": "관리자 신청 목록 조회",
        "parameters": [
          {
            "name": "status",
            "required": false,
            "in": "query",
            "schema": {
              "enum": [
                "RECEIVED",
                "REVIEWING",
                "REMODELING",
                "LEASING",
                "COMPLETED",
                "REJECTED"
              ],
              "type": "string"
            }
          },
          {
            "name": "search",
            "required": false,
            "in": "query",
            "schema": {
              "example": "홍길동 또는 0101234",
              "type": "string"
            }
          },
          {
            "name": "sort",
            "required": false,
            "in": "query",
            "schema": {
              "example": "latest",
              "enum": ["latest", "oldest"],
              "type": "string"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "default": 1,
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "default": 20,
              "example": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": ["applications"],
        "security": [
          {
            "access-token": []
          }
        ]
      }
    },
    "/api/v1/applications/admin/kanban": {
      "get": {
        "operationId": "ApplicationsController_adminKanban",
        "summary": "관리자 칸반 보드 조회",
        "parameters": [
          {
            "name": "search",
            "required": false,
            "in": "query",
            "schema": {
              "example": "홍길동 또는 010-1234",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": ["applications"],
        "security": [
          {
            "access-token": []
          }
        ]
      }
    },
    "/api/v1/applications/admin/{id}": {
      "get": {
        "operationId": "ApplicationsController_adminDetail",
        "summary": "관리자 신청 상세 조회",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": ["applications"],
        "security": [
          {
            "access-token": []
          }
        ]
      }
    },
    "/api/v1/applications/{id}/status": {
      "patch": {
        "operationId": "ApplicationsController_updateStatus",
        "summary": "신청 상태 변경 (관리자)",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateStatusDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": ["applications"],
        "security": [
          {
            "access-token": []
          }
        ]
      }
    },
    "/api/v1/assets/listings": {
      "get": {
        "operationId": "AssetsController_listMarketplace",
        "summary": "매물 리스트 조회 (공공/개인 분리)",
        "parameters": [
          {
            "name": "address",
            "required": false,
            "in": "query",
            "description": "주소 키워드 검색",
            "schema": {
              "example": "제주시 한림읍",
              "type": "string"
            }
          },
          {
            "name": "ownerCategory",
            "required": false,
            "in": "query",
            "schema": {
              "example": "ALL",
              "enum": ["ALL", "PUBLIC", "PRIVATE"],
              "type": "string"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "default": 1,
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "default": 20,
              "example": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": ["assets"]
      }
    },
    "/api/v1/assets/listings/{id}": {
      "get": {
        "operationId": "AssetsController_getListingDetail",
        "summary": "매물 상세 조회",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": ["assets"]
      }
    },
    "/api/v1/assets/{id}/inquiries": {
      "post": {
        "operationId": "AssetsController_createInquiry",
        "summary": "개인 매물 임대 문의 접수",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInquiryDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["assets"]
      }
    },
    "/api/v1/files/upload": {
      "post": {
        "operationId": "FilesController_upload",
        "summary": "신청용 파일 업로드 (회원가입 없이 사용 가능)",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "name": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "refType": {
                    "type": "string"
                  },
                  "refId": {
                    "type": "string"
                  }
                },
                "required": ["file", "name", "phone"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["files"]
      }
    }
  },
  "info": {
    "title": "제주 리-빌리지 API",
    "description": "제주 유휴 자산 매칭 플랫폼 백엔드 API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SignupDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "youth@example.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123!",
            "description": "8~64자 영문/숫자/특수문자 조합"
          },
          "name": {
            "type": "string",
            "example": "홍길동"
          },
          "phone": {
            "type": "string",
            "example": "010-1234-5678"
          },
          "role": {
            "type": "string",
            "enum": ["ELDER", "YOUTH", "ADMIN"],
            "example": "YOUTH"
          }
        },
        "required": ["email", "password", "name"]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "youth@example.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123!"
          }
        },
        "required": ["email", "password"]
      },
      "ApplicationDocumentInputDto": {
        "type": "object",
        "properties": {
          "fileUrl": {
            "type": "string",
            "example": "https://cdn.example.com/docs/registry.pdf"
          },
          "type": {
            "type": "string",
            "enum": [
              "PROPERTY_REGISTER",
              "BUILDING_REGISTER",
              "LAND_REGISTER",
              "FAMILY_RELATION_CERTIFICATE",
              "OTHER"
            ],
            "example": "PROPERTY_REGISTER"
          }
        },
        "required": ["fileUrl"]
      },
      "QuickApplicationDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "홍길동",
            "description": "신규 필드 (권장)"
          },
          "applicantName": {
            "type": "string",
            "example": "홍길동",
            "description": "하위 호환 필드"
          },
          "phone": {
            "type": "string",
            "example": "010-1234-5678",
            "description": "하이픈 포함 입력 허용"
          },
          "email": {
            "type": "string",
            "example": "owner@example.com"
          },
          "assetType": {
            "type": "string",
            "enum": ["EMPTY_HOUSE", "WAREHOUSE", "FIELD", "OTHER"],
            "example": "EMPTY_HOUSE"
          },
          "detectedAssetType": {
            "type": "string",
            "enum": ["EMPTY_HOUSE", "WAREHOUSE", "FIELD", "OTHER"],
            "example": "EMPTY_HOUSE"
          },
          "address": {
            "type": "string",
            "example": "제주특별자치도 제주시 한림읍 ..."
          },
          "detectedAddress": {
            "type": "string",
            "example": "제주특별자치도 제주시 한림읍 ..."
          },
          "areaSqm": {
            "type": "number",
            "example": 72
          },
          "detectedAreaSqm": {
            "type": "number",
            "example": 72
          },
          "latitude": {
            "type": "number",
            "example": 33.4996
          },
          "longitude": {
            "type": "number",
            "example": 126.5312
          },
          "photoUrls": {
            "example": ["https://cdn.example.com/building-1.jpg"],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "documentUrls": {
            "example": ["https://cdn.example.com/registry.pdf"],
            "description": "레거시 문서 URL 리스트",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "documentFiles": {
            "description": "문서 유형 포함 문서 리스트",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApplicationDocumentInputDto"
            }
          },
          "notes": {
            "type": "string",
            "example": "건물 관련 추가 설명"
          },
          "assetId": {
            "type": "string",
            "format": "uuid",
            "deprecated": true,
            "description": "더 이상 사용하지 않습니다. 신청 시 빈집 자산은 항상 신규 생성됩니다."
          },
          "desiredStartDate": {
            "type": "string",
            "example": "2026-05-01",
            "format": "date"
          }
        },
        "required": ["phone"]
      },
      "RequestVerificationDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "010-1234-5678"
          }
        },
        "required": ["phone"]
      },
      "VerifyCodeDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "010-1234-5678"
          },
          "code": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": ["phone", "code"]
      },
      "LookupApplicationDetailDto": {
        "type": "object",
        "properties": {
          "applicationId": {
            "type": "string",
            "format": "uuid"
          },
          "phone": {
            "type": "string",
            "example": "010-1234-5678"
          },
          "code": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": ["applicationId", "phone", "code"]
      },
      "CancelApplicationDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "010-1234-5678"
          },
          "code": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": ["phone", "code"]
      },
      "UpdateStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "RECEIVED",
              "REVIEWING",
              "REMODELING",
              "LEASING",
              "COMPLETED",
              "REJECTED"
            ],
            "example": "REVIEWING"
          },
          "rejectReason": {
            "type": "string",
            "example": "사업계획 보완 필요"
          },
          "residentAgeGroup": {
            "type": "string",
            "example": "20대, 30대"
          },
          "leasePurpose": {
            "type": "string",
            "example": "카페 창업"
          },
          "occupantCount": {
            "type": "number",
            "example": 2
          },
          "remodelSummary": {
            "type": "string",
            "example": "주방/전기 배선/화장실 리모델링 완료"
          },
          "managerContact": {
            "type": "string",
            "example": "제주시 건축과 064-000-0000"
          }
        },
        "required": ["status"]
      },
      "CreateInquiryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "홍길동"
          },
          "phone": {
            "type": "string",
            "example": "010-1234-5678"
          },
          "email": {
            "type": "string",
            "example": "owner@example.com"
          },
          "purpose": {
            "type": "string",
            "example": "게스트하우스 운영"
          },
          "householdType": {
            "type": "string",
            "example": "가족"
          },
          "headCount": {
            "type": "number",
            "example": 2
          },
          "message": {
            "type": "string",
            "example": "현장 확인 가능한 날짜를 안내 부탁드립니다."
          }
        },
        "required": ["name", "phone", "purpose"]
      }
    }
  }
}
